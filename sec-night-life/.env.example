# SEC Nightlife — Frontend environment variables
# Copy to .env.local for local development.
# On Vercel: set in the FRONTEND project → Settings → Environment Variables.
# VITE_* vars are baked in at build time — redeploy after changes.

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:4000

# Public app URL for share links and ticket QR codes
VITE_PUBLIC_APP_URL=http://localhost:5173

# Cloudinary — browser uploads (unsigned preset only; no API secret here)
VITE_CLOUDINARY_CLOUD_NAME=founder_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=sec_unsigned_uploads

# Google Maps — founder-owned key; restrict by domain + app bundle IDs in production
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_browser_key

# Paystack public key (optional — backend can expose via /api/payments/paystack-public-key)
# VITE_PAYSTACK_PUBLIC_KEY=pk_test_or_live_key

# Sentry error monitoring (optional — leave unset to disable)
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
