# SEC Nightlife — Backend environment variables
# Copy to backend/.env for local development.
# On Vercel: set in the BACKEND project → Settings → Environment Variables.

# ── Database (Neon) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/sec_nightlife
# Optional: direct Neon URL for migrations on Vercel build
# DIRECT_DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/sec_nightlife?sslmode=require

# ── Auth (generate unique 64+ char secrets for production) ─────────────────────
JWT_ACCESS_SECRET=generate_with_node_crypto_randomBytes_64_hex
JWT_REFRESH_SECRET=generate_a_different_64_char_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=365d

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
# Production: CORS_ORIGIN=https://secnightlife.com  APP_URL=https://secnightlife.com

# ── Cloudinary (founder account — backend only for API secret) ───────────────
CLOUDINARY_CLOUD_NAME=founder_cloud_name_here
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (Resend — required in production) ──────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=SEC Nightlife <noreply@yourdomain.com>
# SUPPORT_CONTACT_EMAIL=support@yourdomain.com
# ADMIN_CONTACT_EMAIL=admin@yourdomain.com

# ── Payments (Paystack — configure live keys before go-live) ─────────────────
# PAYSTACK_SECRET_KEY=sk_live_...
# PAYSTACK_PUBLIC_KEY=pk_live_...

# ── Cron (Vercel scheduled jobs — same value as Vercel Cron auth) ────────────
# CRON_SECRET=random_string_for_vercel_cron

# ── Admin ────────────────────────────────────────────────────────────────────
# SUPER_ADMIN_EMAIL=founder@yourdomain.com

# ── Sentry (optional) ────────────────────────────────────────────────────────
# SENTRY_DSN=https://example@o0.ingest.sentry.io/0

# ── Pusher (optional — post-launch real-time chat upgrade) ───────────────────
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=eu

# ── Dev only — NEVER set true in production ──────────────────────────────────
# SKIP_EMAIL_VERIFICATION=true
# ALLOW_UNVERIFIED_LOGIN=true
