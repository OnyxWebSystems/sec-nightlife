model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Premium Subscription Prep ────────────────────────────────────────────
model ProfileView {
  id        String   @id @default(uuid())
  viewerId  String   @map("viewer_id")
  viewedId  String   @map("viewed_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([viewerId])
  @@index([viewedId])
  @@index([createdAt])
  @@map("profile_views")
}

// ─── Reputation Scores (server-computed) ─────────────────────────────────
model ReputationScore {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  score              Float    @default(50)
  attendanceScore    Float    @default(0) @map("attendance_score")
  reportsReceived    Int      @default(0) @map("reports_received")
  blocksReceived     Int      @default(0) @map("blocks_received")
  eventParticipation Int      @default(0) @map("event_participation")
  tableParticipation Int      @default(0) @map("table_participation")
  computedAt         DateTime @default(now()) @map("computed_at")

  @@index([userId])
  @@index([score])
  @@map("reputation_scores")
}

// ─── Future: Live Venue Popularity ───────────────────────────────────────
model VenuePopularity {
  id              String   @id @default(uuid())
  venueId         String   @map("venue_id")
  eventId         String?  @map("event_id")
  currentCheckIns Int      @default(0) @map("current_check_ins")
  popularityScore Float    @default(0) @map("popularity_score")
  queueTime       Int?     @map("queue_time")
  lastUpdatedAt   DateTime @default(now()) @map("last_updated_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, eventId])
  @@index([venueId])
  @@index([popularityScore])
  @@map("venue_popularity")
}

/// Private celebrations / venue coordination requests (weddings, umemulo, etc.)
model CelebrationRequest {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  venueId         String?  @map("venue_id")
  eventType       String   @map("event_type")
  title           String
  description     String?  @db.Text
  guestCount      Int?     @map("guest_count")
  preferredDate   DateTime? @map("preferred_date")
  status          String   @default("open")
  venueNotes      String?  @map("venue_notes") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue? @relation(fields: [venueId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([venueId])
  @@index([status])
  @@map("celebration_requests")
}

// ─── Future: Table Booking & Split Payments ──────────────────────────────
model TableBooking {
  id              String   @id @default(uuid())
  tableId         String   @map("table_id")
  organizerUserId String   @map("organizer_user_id")
  totalCost       Float    @map("total_cost")
  splitCount      Int      @default(1) @map("split_count")
  status          String   @default("pending")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  table  Table               @relation(fields: [tableId], references: [id], onDelete: Cascade)
  splits TableBookingSplit[]

  @@index([tableId])
  @@index([organizerUserId])
  @@index([status])
  @@map("table_bookings")
}

model TableBookingSplit {
  id            String    @id @default(uuid())
  bookingId     String    @map("booking_id")
  userId        String    @map("user_id")
  amount        Float
  paymentStatus String    @default("pending") @map("payment_status")
  paymentRef    String?   @map("payment_ref")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  booking TableBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, userId])
  @@index([bookingId])
  @@index([userId])
  @@index([paymentStatus])
  @@map("table_booking_splits")
}

// ─── Future: Party Groups / Crews ────────────────────────────────────────
model PartyGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  avatarUrl   String?  @map("avatar_url")
  createdBy   String   @map("created_by")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members     PartyGroupMember[]
  invitations PartyGroupInvitation[]
  events      PartyGroupEvent[]

  @@index([createdBy])
  @@map("party_groups")
}

model PartyGroupMember {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  group PartyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("party_group_members")
}

model PartyGroupInvitation {
  id          String    @id @default(uuid())
  groupId     String    @map("group_id")
  inviterId   String    @map("inviter_id")
  inviteeId   String    @map("invitee_id")
  status      String    @default("pending")
  createdAt   DateTime  @default(now()) @map("created_at")
  respondedAt DateTime? @map("responded_at")

  group PartyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, inviteeId])
  @@index([groupId])
  @@index([inviteeId])
  @@index([status])
  @@map("party_group_invitations")
}

model PartyGroupEvent {
  id        String    @id @default(uuid())
  groupId   String    @map("group_id")
  eventId   String?   @map("event_id")
  venueId   String?   @map("venue_id")
  title     String
  date      DateTime?
  status    String    @default("planning")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  group PartyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([eventId])
  @@map("party_group_events")
}
