generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  VENUE
  FREELANCER
  ADMIN
  SUPER_ADMIN
  MODERATOR
}

enum VenueComplianceStatus {
  pending
  approved
  rejected
}

enum ComplianceDocumentType {
  LIQUOR_LICENCE
  BUSINESS_REGISTRATION
  HEALTH_CERTIFICATE
  TAX_CLEARANCE
  OTHER
}

enum ComplianceDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  draft
  published
  cancelled
}

enum TableStatus {
  open
  full
  closed
}

enum TableCategory {
  general
  vip
}

enum ReportStatus {
  pending
  in_review
  resolved
  action_taken
  dismissed
}

enum ReportCategory {
  fraud
  fake_event
  gbv_or_harassment
  scam_or_payment_issue
  impersonation
  hate_or_abuse
  other
}

enum ReportPriority {
  low
  medium
  high
  critical
}

enum JobType {
  FULL_TIME
  PART_TIME
  ONCE_OFF
  CONTRACT
}

enum CompensationType {
  FIXED
  NEGOTIABLE
  UNPAID_TRIAL
}

enum CompensationPer {
  HOUR
  MONTH
  COMMISSION
  ONCE_OFF
}

enum JobStatus {
  OPEN
  CLOSED
  FILLED
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
  HIRED
}

enum PromotionType {
  VENUE_PROMOTION
  EVENT_PROMOTION
  SPECIAL_OFFER
  ANNOUNCEMENT
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum ImpressionType {
  VIEW
  CLICK
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
  DECLINED
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  DIRECT_MESSAGE
  GROUP_MESSAGE
  EVENT_JOINED
  TABLE_JOINED
  JOIN_REQUEST_ACCEPTED
  USER_REVIEW_RECEIVED
  ADMIN_FLAGGED_USER_REVIEW
  ADMIN_FLAGGED_VENUE_REVIEW
  REVIEW_REMOVED_BY_ADMIN
  TABLE_INVITE
  IDENTITY_VERIFICATION_REMINDER
  EVENT_INTEREST_REMINDER
}

enum LegalDocumentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  PROMOTER_CODE_OF_CONDUCT
}

enum FriendActivityType {
  JOINED_EVENT
  JOINED_TABLE
  HOSTED_TABLE
  INTERACTED_PROMOTION
}

enum HousePartyStatus {
  DRAFT
  PENDING_PAYMENT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum HostedTableStatus {
  DRAFT
  ACTIVE
  FULL
  CLOSED
}

enum GuestGenderPreference {
  ANY
  MALE_ONLY
  FEMALE_ONLY
  OTHER_ONLY
}

enum HostingTableCategory {
  GENERAL
  VIP
}

enum TicketKind {
  EVENT_TICKET
  TABLE_JOIN
  HOSTED_TABLE_JOIN
  HOUSE_PARTY
  TABLE_HOST_FEE
  EXTERNAL_HOSTED_LISTING
  VENUE_TABLE_JOIN
}

enum PayoutRecipientType {
  USER
  VENUE
  PLATFORM
}

enum PayoutLedgerStatus {
  PENDING
  TRANSFERRED
  FAILED
  SKIPPED_NO_RECIPIENT
}

enum TableSourceType {
  IN_APP_EVENT
  EXTERNAL_VENUE
}

enum AttendeeStatus {
  GOING
  PENDING
  WAITLISTED
  CANCELLED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum TableEventType {
  CLUB_TABLE
  HOUSE_PARTY
  BOAT_PARTY
  RESTAURANT
  OTHER
}

enum VenueTableStatus {
  AVAILABLE
  PARTIALLY_FILLED
  FULL
  LOCKED
  CLOSED
}

enum VenueTableMemberStatus {
  PENDING_PAYMENT
  PENDING_VENUE_REVIEW
  APPROVED
  DECLINED
  CONFIRMED
  LEFT
}

enum MinSpendSettlement {
  PREPAY_MENU
  PREPAY_LUMP
  PAY_ON_ARRIVAL
}

// ─── Users & Auth ─────────────────────────────────────────────────────────
// Party Goers (USER) and Business Owners (VENUE) can share the same email as separate accounts
model User {
  id                    String    @id @default(uuid())
  email                 String
  passwordHash          String    @map("password_hash")
  role                  UserRole  @default(USER)
  username              String    @unique @map("username")
  fullName              String?   @map("full_name")
  emailVerified         Boolean   @default(false) @map("email_verified")
  verificationTokenHash String?   @map("verification_token_hash")
  verificationExpiry    DateTime? @map("verification_expiry")
  resetTokenHash        String?   @map("reset_token_hash")
  resetTokenExpiry      DateTime? @map("reset_token_expiry")
  isPremium             Boolean   @default(false) @map("is_premium")
  paystackRecipientCode String?   @map("paystack_recipient_code")
  suspendedAt           DateTime? @map("suspended_at")
  suspendedReason       String?   @map("suspended_reason")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  // Relations
  venueOwner                  Venue[]                    @relation("VenueOwner")
  userProfile                 UserProfile?
  hostedTables                Table[]                    @relation("TableHost")
  housePartiesHosted          HouseParty[]               @relation("HousePartyHost")
  housePartyAttendances       HousePartyAttendee[]
  hostedTablesV2              HostedTable[]              @relation("HostedTableHost")
  hostedTableMemberships      HostedTableMember[]
  tableInvitesSent            TableInvite[]              @relation("TableInviter")
  tableInvitesReceived        TableInvite[]              @relation("TableInvitee")
  housePartyJobsHosted        HousePartyJob[]            @relation("HousePartyJobHost")
  housePartyJobApplications   HousePartyJobApplication[]
  housePartyJobMessagesSent   HousePartyJobMessage[]     @relation("HousePartyJobMessageSender")
  venueTableMemberships       VenueTableMember[]
  blocksInitiated             Block[]                    @relation("BlockInitiator")
  blocksReceived              Block[]                    @relation("BlockTarget")
  reportsInitiated            Report[]                   @relation("ReportInitiator")
  complianceDocumentsReviewed ComplianceDocument[]       @relation("ReviewedByUser")
  adminReviewerAdditions      AdminReviewer[]            @relation("AddedByUser")
  adminDashboardDelegations   AdminDashboardDelegate[]   @relation("AddedByAdminDashboardUser")
  auditLogs                   AuditLog[]
  refreshTokens               RefreshToken[]
  jobApplications             JobApplication[]
  sentJobMessages             JobMessage[]               @relation("MessageSender")
  friendshipsInitiated        Friendship[]               @relation("FriendRequester")
  friendshipsReceived         Friendship[]               @relation("FriendReceiver")
  conversationsAsParticipantA Conversation[]             @relation("ConversationParticipantA")
  conversationsAsParticipantB Conversation[]             @relation("ConversationParticipantB")
  directMessagesSent          DirectMessage[]            @relation("DirectMessageSender")
  groupChatMemberships        GroupChatMember[]
  groupChatMessagesSent       GroupChatMessage[]         @relation("GroupChatMessageSender")
  hostedTableGroupChatMemberships HostedTableGroupChatMember[]
  hostedTableGroupChatMessagesSent HostedTableGroupChatMessage[] @relation("HostedTableGroupChatMessageSender")
  inAppNotifications          InAppNotification[]
  friendActivities            FriendActivity[]
  reviewsGiven                UserReview[]               @relation("ReviewsGiven")
  reviewsReceived             UserReview[]               @relation("ReviewsReceived")
  venueReviewsGiven           VenueReview[]              @relation("VenueReviewsGiven")
  venueFollows                VenueFollow[]
  legalAcceptances            LegalDocumentAcceptance[]
  promoterFollowers           PromoterFollow[]           @relation("PromoterFollowers")
  promoterFollowing           PromoterFollow[]           @relation("PromoterFollowing")
  eventInterestRemindersSent  EventInterestReminderSent[]
  tickets                     Ticket[]
  payoutLedgersAsRecipient    PayoutLedger[]             @relation("PayoutRecipientUser")
  eventVenueTableBookings     EventVenueTableBooking[]
  celebrationRequests         CelebrationRequest[]
  ticketsAdmittedAsStaff    Ticket[]                   @relation("TicketAdmittedBy")

  @@unique([email, role])
  @@index([email])
  @@index([username])
  @@index([role])
  @@map("users")
}

model LegalDocumentAcceptance {
  id           String            @id @default(cuid())
  userId       String            @map("user_id")
  documentType LegalDocumentType @map("document_type")
  version      String
  acceptedAt   DateTime          @default(now()) @map("accepted_at")
  ipAddress    String?           @map("ip_address")
  userAgent    String?           @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, documentType, acceptedAt])
  @@index([documentType, version])
  @@map("legal_document_acceptances")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model UserProfile {
  id                        String    @id @default(uuid())
  userId                    String    @unique @map("user_id")
  username                  String?
  bio                       String?
  city                      String?
  avatarUrl                 String?   @map("avatar_url")
  favoriteDrink             String?   @map("favorite_drink")
  gender                    String?
  dateOfBirth               String?   @map("date_of_birth")
  idDocumentUrl             String?   @map("id_document_url")
  ageVerified               Boolean   @default(false) @map("age_verified")
  verificationStatus        String    @default("pending") @map("verification_status")
  verificationRejectionNote String?   @map("verification_rejection_note") @db.Text
  paymentSetupComplete      Boolean   @default(false) @map("payment_setup_complete")
  isVerifiedPromoter        Boolean   @default(false) @map("is_verified_promoter")
  socialReputation          Float     @default(0) @map("social_reputation")
  behaviourScore            Float     @default(100) @map("behaviour_score")
  serviceRatingAvg          Float     @default(0) @map("service_rating_avg")
  serviceRatingCount        Int       @default(0) @map("service_rating_count")
  leaderboardHidden         Boolean   @default(false) @map("leaderboard_hidden")
  leaderboardHiddenReason   String?   @map("leaderboard_hidden_reason") @db.Text
  leaderboardHiddenUntil    DateTime? @map("leaderboard_hidden_until")
  promoterVerifiedAt        DateTime? @map("promoter_verified_at")
  promoterVerifiedBy        String?   @map("promoter_verified_by")
  promoterRevokedAt         DateTime? @map("promoter_revoked_at")
  promoterRevokedBy         String?   @map("promoter_revoked_by")
  promoterVerificationNote  String?   @map("promoter_verification_note") @db.Text
  promoterJobsAccepted      Int       @default(0) @map("promoter_jobs_accepted")
  isPromoterStandard        Boolean   @default(false) @map("is_promoter_standard")
  interests                 String[]  @default([])
  musicPreferences          String[]  @default([]) @map("music_preferences")
  friends                   String[]  @default([])
  followedVenues            String[]  @default([]) @map("followed_venues")
  interestedEvents          String[]  @default([]) @map("interested_events")
  onboardingComplete        Boolean   @default(false) @map("onboarding_complete")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")
  deletedAt                 DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// Dedupe T-3h interest reminders (cron idempotency).
model EventInterestReminderSent {
  id      String   @id @default(cuid())
  userId  String   @map("user_id")
  eventId String   @map("event_id")
  sentAt  DateTime @default(now()) @map("sent_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@map("event_interest_reminders_sent")
}

// ─── Tier 1: Venues ───────────────────────────────────────────────────────
model Venue {
  id                          String                @id @default(uuid())
  ownerUserId                 String                @map("owner_user_id")
  name                        String
  venueType                   String                @map("venue_type")
  city                        String
  address                     String?
  suburb                      String?
  province                    String?
  latitude                    Float?
  longitude                   Float?
  bio                         String?
  isVerified                  Boolean               @default(false) @map("is_verified")
  complianceStatus            VenueComplianceStatus @default(pending) @map("compliance_status")
  complianceRejectionNote     String?               @map("compliance_rejection_note") @db.Text
  logoUrl                     String?               @map("logo_url")
  coverImageUrl               String?               @map("cover_image_url")
  phone                       String?
  email                       String?
  website                     String?
  instagram                   String?
  venuePaystackSubaccountCode String?               @map("venue_paystack_subaccount_code")
  paystackRecipientCode       String?               @map("paystack_recipient_code")
  capacity                    Int?
  ageLimit                    Int?                  @map("age_limit")
  rating                      Float                 @default(0)
  ratingCount                 Int                   @default(0) @map("rating_count")
  performanceScore            Float                 @default(0) @map("performance_score")
  transparencyScore           Float                 @default(0) @map("transparency_score")
  acceptsDayBookings          Boolean               @default(false) @map("accepts_day_bookings")
  hostTableFeeZar             Float                 @default(0) @map("host_table_fee_zar")
  customTableBookingFeeZar  Float                 @default(0) @map("custom_table_booking_fee_zar")
  bookingPolicies             Json?                 @map("booking_policies")
  externalBookingLinks        Json?                 @map("external_booking_links")
  createdAt                   DateTime              @default(now()) @map("created_at")
  updatedAt                   DateTime              @updatedAt @map("updated_at")
  deletedAt                   DateTime?             @map("deleted_at")

  owner               User                 @relation("VenueOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  celebrationRequests CelebrationRequest[]
  events              Event[]
  tables              Table[]
  jobs                Job[]
  jobPostings         JobPosting[]
  promotedPosts       Promotion[]
  reviews             VenueReview[]
  blockedUsers        VenueBlockedUser[]
  popularity          VenuePopularity[]
  complianceDocuments ComplianceDocument[]
  follows             VenueFollow[]
  venueTables         VenueTable[]
  menuItems           VenueMenuItem[]
  payoutLedgers       PayoutLedger[] @relation("PayoutRecipientVenue")
  eventVenueTableBookings EventVenueTableBooking[]

  @@index([ownerUserId])
  @@index([city])
  @@index([complianceStatus])
  @@map("venues")
}

model MenuCatalogItem {
  id              String   @id
  name            String
  topCategory     String   @map("top_category")
  subCategory     String?  @map("sub_category")
  defaultPriceZar Float    @map("default_price_zar")
  imageUrl        String?  @map("image_url")
  searchText      String?  @map("search_text")
  brand           String?
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  venueMenuItems VenueMenuItem[]

  @@index([topCategory, subCategory])
  @@index([isActive])
  @@map("menu_catalog_items")
}

model VenueMenuItem {
  id            String   @id @default(cuid())
  venueId       String   @map("venue_id")
  catalogItemId String?  @map("catalog_item_id")
  name          String
  category      String   @default("Other")
  subCategory   String?  @map("sub_category")
  price         Float
  imageUrl      String?  @map("image_url")
  isAvailable   Boolean  @default(true) @map("is_available")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  venue         Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  catalogItem   MenuCatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)

  @@unique([venueId, catalogItemId])
  @@index([venueId])
  @@map("venue_menu_items")
}

model VenueFollow {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  venueId   String   @map("venue_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@index([userId])
  @@index([venueId])
  @@map("venue_follows")
}

model ComplianceDocument {
  id String @id @default(cuid())

  venueId String @map("venue_id")
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  documentType ComplianceDocumentType @map("document_type")
  fileUrl      String                 @map("file_url") @db.Text
  fileName     String                 @map("file_name")

  uploadedAt DateTime @default(now()) @map("uploaded_at")

  status ComplianceDocumentStatus @default(PENDING)

  rejectionReason String?   @map("rejection_reason") @db.Text
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by")

  reviewedByUser User? @relation("ReviewedByUser", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([venueId])
  @@index([status])
  @@index([documentType])
  @@map("compliance_documents")
}

model AdminReviewer {
  id String @id @default(cuid())

  email String @unique
  name  String

  addedAt  DateTime @default(now()) @map("added_at")
  isActive Boolean  @default(true) @map("is_active")

  addedByUserId String @map("added_by_user_id")
  addedByUser   User   @relation("AddedByUser", fields: [addedByUserId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@map("admin_reviewers")
}

model AdminDashboardDelegate {
  id String @id @default(cuid())

  email String @unique
  name  String

  addedAt  DateTime @default(now()) @map("added_at")
  isActive Boolean  @default(true) @map("is_active")

  addedByUserId String @map("added_by_user_id")
  addedByUser   User   @relation("AddedByAdminDashboardUser", fields: [addedByUserId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@map("admin_dashboard_delegates")
}

model VenueReview {
  id         String    @id @default(cuid())
  reviewerId String    @map("user_id")
  venueId    String    @map("venue_id")
  rating     Int
  comment    String    @db.Text
  flagged    Boolean   @default(false)
  flagReason String?   @map("flag_reason") @db.Text
  flaggedAt  DateTime? @map("flagged_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  reviewer User  @relation("VenueReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  venue    Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, venueId])
  @@index([venueId])
  @@index([reviewerId])
  @@index([flagged])
  @@map("venue_reviews")
}

model VenueBlockedUser {
  id        String   @id @default(uuid())
  venueId   String   @map("venue_id")
  userId    String   @map("user_id")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, userId])
  @@index([venueId])
  @@map("venue_blocked_users")
}

// ─── Events & Tables ──────────────────────────────────────────────────────
model Event {
  id                String      @id @default(uuid())
  venueId           String      @map("venue_id")
  title             String
  description       String?
  date              DateTime
  city              String
  locationAddress   String?     @map("location_address")
  locationCity      String?     @map("location_city")
  locationSuburb    String?     @map("location_suburb")
  locationProvince  String?     @map("location_province")
  status            EventStatus @default(draft)
  isFeatured        Boolean     @default(false) @map("is_featured")
  coverImageUrl     String?     @map("cover_image_url")
  bannerUrl         String?     @map("banner_url")
  ticketTiers       Json?       @map("ticket_tiers")
  startTime         String?     @map("start_time")
  /// When the event is considered ended (QR, feeds, listings). Backfilled for legacy rows.
  endsAt            DateTime?   @map("ends_at")
  hasEntranceFee    Boolean     @default(false) @map("has_entrance_fee")
  entranceFeeAmount Float?      @map("entrance_fee_amount")
  hostingConfig     Json?       @map("hosting_config")
  /// Optional bcrypt hash for venue door staff when recording ticket admits (4–8 digits).
  doorCheckPinHash   String?     @map("door_check_pin_hash")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  venue         Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  tables        Table[]
  hostedTables  HostedTable[]
  venueTables   VenueTable[]
  jobs          Job[]
  attendees     EventAttendance[]
  promotedPosts Promotion[]
  groupChat     GroupChat?
  userReviews   UserReview[]
  eventInterestRemindersSent EventInterestReminderSent[]
  eventVenueTableBookings    EventVenueTableBooking[]

  @@index([venueId])
  @@index([date])
  @@index([endsAt])
  @@index([status])
  @@index([city])
  @@map("events")
}

model EventAttendance {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  confirmed Boolean  @default(false)
  checkedIn Boolean  @default(false) @map("checked_in")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_attendance")
}

model Table {
  id              String      @id @default(uuid())
  eventId         String      @map("event_id")
  venueId         String      @map("venue_id")
  hostUserId      String      @map("host_user_id")
  name            String
  tableCategory   TableCategory @default(general) @map("table_category")
  status          TableStatus @default(open)
  maxGuests       Int         @map("max_guests")
  currentGuests   Int         @default(0) @map("current_guests")
  minSpend        Float?      @map("min_spend")
  joiningFee              Float?                 @map("joining_fee")
  isPublic                Boolean                @default(true) @map("is_public")
  guestGenderPreference   GuestGenderPreference  @default(ANY) @map("guest_gender_preference")
  hostFeePaystackRef      String?                @unique @map("host_fee_paystack_ref")
  members                 Json                   @default("[]")
  pendingRequests         Json                   @default("[]") @map("pending_requests")
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime               @updatedAt @map("updated_at")
  deletedAt               DateTime?              @map("deleted_at")

  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venue       Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  host        User           @relation("TableHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  bookings    TableBooking[]
  userReviews UserReview[]

  @@index([eventId])
  @@index([venueId])
  @@index([hostUserId])
  @@index([status])
  @@map("tables")
}

// ─── Tier 2: Freelancers / Jobs ───────────────────────────────────────────
model Job {
  id                 String    @id @default(uuid())
  venueId            String?   @map("venue_id")
  eventId            String?   @map("event_id")
  hostEventId        String?   @map("host_event_id")
  title              String
  jobType            String    @map("job_type")
  status             String    @default("open")
  spotsAvailable     Int       @map("spots_available")
  spotsFilled        Int       @default(0) @map("spots_filled")
  city               String
  description        String?   @db.Text
  suggestedPayAmount Int?      @map("suggested_pay_amount")
  suggestedPayType   String?   @map("suggested_pay_type")
  startTime          String?   @map("start_time")
  endTime            String?   @map("end_time")
  contactDetails     String?   @map("contact_details") @db.Text
  date               String?
  applicants         Json      @default("[]")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  venue     Venue?     @relation(fields: [venueId], references: [id], onDelete: SetNull)
