  componentZar      Float?   @map("component_zar")
  selectedMenuItems Json?    @map("selected_menu_items")
  hostingTierName   String?  @map("hosting_tier_name")
  hostingCategory   String?  @map("hosting_category")
  menuTotalZar      Float?   @map("menu_total_zar")
  bookingFeeZar     Float?   @map("booking_fee_zar")
  minimumSpendZar   Float?   @map("minimum_spend_zar")
  platformFeeZar    Float?   @map("platform_fee_zar")
  settlementMode    String?  @map("settlement_mode")
  declineReason     String?  @map("decline_reason") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")

  venue       Venue       @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  hostedTable HostedTable @relation(fields: [hostedTableId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([eventId])
  @@index([hostedTableId])
  @@index([userId])
  @@map("event_venue_table_bookings")
}

model HostedTableGroupChat {
  id              String    @id @default(cuid())
  hostedTableId   String    @unique @map("hosted_table_id")
  name            String
  lastMessageAt   DateTime? @map("last_message_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  hostedTable HostedTable                   @relation(fields: [hostedTableId], references: [id], onDelete: Cascade)
  members     HostedTableGroupChatMember[]
  messages    HostedTableGroupChatMessage[]

  @@index([lastMessageAt])
  @@map("hosted_table_group_chats")
}

model HostedTableGroupChatMember {
  id                    String    @id @default(cuid())
  hostedTableGroupChatId String   @map("hosted_table_group_chat_id")
  userId                String    @map("user_id")
  joinedAt              DateTime  @default(now()) @map("joined_at")
  lastReadAt            DateTime? @map("last_read_at")

  groupChat HostedTableGroupChat @relation(fields: [hostedTableGroupChatId], references: [id], onDelete: Cascade)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hostedTableGroupChatId, userId])
  @@index([hostedTableGroupChatId])
  @@index([userId])
  @@map("hosted_table_group_chat_members")
}

model HostedTableGroupChatMessage {
  id                    String   @id @default(cuid())
  hostedTableGroupChatId String  @map("hosted_table_group_chat_id")
  senderUserId          String  @map("sender_user_id")
  body                    String  @db.Text
  sentAt                  DateTime @default(now()) @map("sent_at")

  groupChat HostedTableGroupChat @relation(fields: [hostedTableGroupChatId], references: [id], onDelete: Cascade)
  sender    User                 @relation("HostedTableGroupChatMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([hostedTableGroupChatId, sentAt])
