generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  VENUE
  FREELANCER
  ADMIN
  SUPER_ADMIN
  MODERATOR
}

enum VenueComplianceStatus {
  pending
  approved
  rejected
}

enum ComplianceDocumentType {
  LIQUOR_LICENCE
  BUSINESS_REGISTRATION
  HEALTH_CERTIFICATE
  TAX_CLEARANCE
  OTHER
}

enum ComplianceDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  draft
  published
  cancelled
}

enum TableStatus {
  open
  full
  closed
}

enum ReportStatus {
  pending
  resolved
  dismissed
}

enum JobType {
  FULL_TIME
  PART_TIME
  ONCE_OFF
  CONTRACT
}

enum CompensationType {
  FIXED
  NEGOTIABLE
  UNPAID_TRIAL
}

enum CompensationPer {
  HOUR
  MONTH
  COMMISSION
  ONCE_OFF
}

enum JobStatus {
  OPEN
  CLOSED
  FILLED
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
  HIRED
}

enum PromotionType {
  VENUE_PROMOTION
  EVENT_PROMOTION
  SPECIAL_OFFER
  ANNOUNCEMENT
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum ImpressionType {
  VIEW
  CLICK
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
  DECLINED
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  DIRECT_MESSAGE
  GROUP_MESSAGE
  EVENT_JOINED
  TABLE_JOINED
  JOIN_REQUEST_ACCEPTED
  USER_REVIEW_RECEIVED
  ADMIN_FLAGGED_USER_REVIEW
  ADMIN_FLAGGED_VENUE_REVIEW
  REVIEW_REMOVED_BY_ADMIN
}

enum FriendActivityType {
  JOINED_EVENT
  JOINED_TABLE
  HOSTED_TABLE
  INTERACTED_PROMOTION
}

// ─── Users & Auth ─────────────────────────────────────────────────────────
// Party Goers (USER) and Business Owners (VENUE) can share the same email as separate accounts
model User {
  id                    String    @id @default(uuid())
  email                 String
  passwordHash          String    @map("password_hash")
  role                  UserRole  @default(USER)
  username              String    @unique @map("username")
  fullName              String?   @map("full_name")
  emailVerified         Boolean   @default(false) @map("email_verified")
  verificationTokenHash String?   @map("verification_token_hash")
  verificationExpiry    DateTime? @map("verification_expiry")
  resetTokenHash        String?   @map("reset_token_hash")
  resetTokenExpiry      DateTime? @map("reset_token_expiry")
  isPremium             Boolean   @default(false) @map("is_premium")
  suspendedAt           DateTime? @map("suspended_at")
  suspendedReason       String?   @map("suspended_reason")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  // Relations
  venueOwner                  Venue[]              @relation("VenueOwner")
  userProfile                 UserProfile?
  hostedTables                Table[]              @relation("TableHost")
  blocksInitiated             Block[]              @relation("BlockInitiator")
  blocksReceived              Block[]              @relation("BlockTarget")
  reportsInitiated            Report[]             @relation("ReportInitiator")
  complianceDocumentsReviewed ComplianceDocument[] @relation("ReviewedByUser")
  adminReviewerAdditions      AdminReviewer[]      @relation("AddedByUser")
  auditLogs                   AuditLog[]
  refreshTokens               RefreshToken[]
  jobApplications             JobApplication[]
  sentJobMessages             JobMessage[]         @relation("MessageSender")
  friendshipsInitiated        Friendship[]         @relation("FriendRequester")
  friendshipsReceived         Friendship[]         @relation("FriendReceiver")
  conversationsAsParticipantA Conversation[]       @relation("ConversationParticipantA")
  conversationsAsParticipantB Conversation[]       @relation("ConversationParticipantB")
  directMessagesSent          DirectMessage[]      @relation("DirectMessageSender")
  groupChatMemberships        GroupChatMember[]
  groupChatMessagesSent       GroupChatMessage[]   @relation("GroupChatMessageSender")
  inAppNotifications          InAppNotification[]
  friendActivities            FriendActivity[]
  reviewsGiven                UserReview[]         @relation("ReviewsGiven")
  reviewsReceived             UserReview[]         @relation("ReviewsReceived")
  venueReviewsGiven           VenueReview[]        @relation("VenueReviewsGiven")

  @@unique([email, role])
  @@index([email])
  @@index([username])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model UserProfile {
  id                        String    @id @default(uuid())
  userId                    String    @unique @map("user_id")
  username                  String?
  bio                       String?
  city                      String?
  avatarUrl                 String?   @map("avatar_url")
  favoriteDrink             String?   @map("favorite_drink")
  dateOfBirth               String?   @map("date_of_birth")
  idDocumentUrl             String?   @map("id_document_url")
  ageVerified               Boolean   @default(false) @map("age_verified")
  verificationStatus        String    @default("pending") @map("verification_status")
  verificationRejectionNote String?   @map("verification_rejection_note") @db.Text
  paymentSetupComplete      Boolean   @default(false) @map("payment_setup_complete")
  isVerifiedPromoter        Boolean   @default(false) @map("is_verified_promoter")
  socialReputation          Float     @default(0) @map("social_reputation")
  behaviourScore            Float     @default(100) @map("behaviour_score")
  serviceRatingAvg          Float     @default(0) @map("service_rating_avg")
  serviceRatingCount        Int       @default(0) @map("service_rating_count")
  interests                 String[]  @default([])
  musicPreferences          String[]  @default([]) @map("music_preferences")
  friends                   String[]  @default([])
  followedVenues            String[]  @default([]) @map("followed_venues")
  onboardingComplete        Boolean   @default(false) @map("onboarding_complete")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")
  deletedAt                 DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ─── Tier 1: Venues ───────────────────────────────────────────────────────
model Venue {
  id                      String                @id @default(uuid())
  ownerUserId             String                @map("owner_user_id")
  name                    String
  venueType               String                @map("venue_type")
  city                    String
  address                 String?
  suburb                  String?
  province                String?
  latitude                Float?
  longitude               Float?
  bio                     String?
  isVerified              Boolean               @default(false) @map("is_verified")
  complianceStatus        VenueComplianceStatus @default(pending) @map("compliance_status")
  complianceRejectionNote String?               @map("compliance_rejection_note") @db.Text
  logoUrl                 String?               @map("logo_url")
  coverImageUrl           String?               @map("cover_image_url")
  phone                   String?
  email                   String?
  website                 String?
  instagram               String?
  capacity                Int?
  ageLimit                Int?                  @map("age_limit")
  rating                  Float                 @default(0)
  ratingCount             Int                   @default(0) @map("rating_count")
  performanceScore        Float                 @default(0) @map("performance_score")
  transparencyScore       Float                 @default(0) @map("transparency_score")
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  deletedAt               DateTime?             @map("deleted_at")

  owner               User                 @relation("VenueOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  events              Event[]
  tables              Table[]
  jobs                Job[]
  jobPostings         JobPosting[]
  promotedPosts       Promotion[]
  reviews             VenueReview[]
  blockedUsers        VenueBlockedUser[]
  popularity          VenuePopularity[]
  complianceDocuments ComplianceDocument[]

  @@index([ownerUserId])
  @@index([city])
  @@index([complianceStatus])
  @@map("venues")
}

model ComplianceDocument {
  id String @id @default(cuid())

  venueId String @map("venue_id")
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  documentType ComplianceDocumentType @map("document_type")
  fileUrl      String                 @map("file_url") @db.Text
  fileName     String                 @map("file_name")

  uploadedAt DateTime @default(now()) @map("uploaded_at")

  status ComplianceDocumentStatus @default(PENDING)

  rejectionReason String?   @map("rejection_reason") @db.Text
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by")

  reviewedByUser User? @relation("ReviewedByUser", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([venueId])
  @@index([status])
  @@index([documentType])
  @@map("compliance_documents")
}

model AdminReviewer {
  id String @id @default(cuid())

  email String @unique
  name  String

  addedAt  DateTime @default(now()) @map("added_at")
  isActive Boolean  @default(true) @map("is_active")

  addedByUserId String @map("added_by_user_id")
  addedByUser   User   @relation("AddedByUser", fields: [addedByUserId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@map("admin_reviewers")
}

model VenueReview {
  id         String    @id @default(cuid())
  reviewerId String    @map("user_id")
  venueId    String    @map("venue_id")
  rating     Int
  comment    String    @db.Text
  flagged    Boolean   @default(false)
  flagReason String?   @map("flag_reason") @db.Text
  flaggedAt  DateTime? @map("flagged_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  reviewer User  @relation("VenueReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  venue    Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, venueId])
  @@index([venueId])
  @@index([reviewerId])
  @@index([flagged])
  @@map("venue_reviews")
}

model VenueBlockedUser {
  id        String   @id @default(uuid())
  venueId   String   @map("venue_id")
  userId    String   @map("user_id")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, userId])
  @@index([venueId])
  @@map("venue_blocked_users")
}

// ─── Events & Tables ──────────────────────────────────────────────────────
model Event {
  id                String      @id @default(uuid())
  venueId           String      @map("venue_id")
  title             String
  description       String?
  date              DateTime
  city              String
  status            EventStatus @default(draft)
  isFeatured        Boolean     @default(false) @map("is_featured")
  coverImageUrl     String?     @map("cover_image_url")
  bannerUrl         String?     @map("banner_url")
  ticketTiers       Json?       @map("ticket_tiers")
  startTime         String?     @map("start_time")
  hasEntranceFee    Boolean     @default(false) @map("has_entrance_fee")
  entranceFeeAmount Float?      @map("entrance_fee_amount")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  venue         Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  tables        Table[]
  jobs          Job[]
  attendees     EventAttendance[]
  promotedPosts Promotion[]
  groupChat     GroupChat?
  userReviews   UserReview[]

  @@index([venueId])
  @@index([date])
  @@index([status])
  @@index([city])
  @@map("events")
}

model EventAttendance {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  confirmed Boolean  @default(false)
  checkedIn Boolean  @default(false) @map("checked_in")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_attendance")
}

model Table {
  id              String      @id @default(uuid())
  eventId         String      @map("event_id")
  venueId         String      @map("venue_id")
  hostUserId      String      @map("host_user_id")
  name            String
  status          TableStatus @default(open)
  maxGuests       Int         @map("max_guests")
  currentGuests   Int         @default(0) @map("current_guests")
  minSpend        Float?      @map("min_spend")
  joiningFee      Float?      @map("joining_fee")
  members         Json        @default("[]")
  pendingRequests Json        @default("[]") @map("pending_requests")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venue       Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  host        User           @relation("TableHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  bookings    TableBooking[]
  userReviews UserReview[]

  @@index([eventId])
  @@index([venueId])
  @@index([hostUserId])
  @@index([status])
  @@map("tables")
}

// ─── Tier 2: Freelancers / Jobs ───────────────────────────────────────────
model Job {
  id                 String    @id @default(uuid())
  venueId            String?   @map("venue_id")
  eventId            String?   @map("event_id")
  hostEventId        String?   @map("host_event_id")
  title              String
  jobType            String    @map("job_type")
  status             String    @default("open")
  spotsAvailable     Int       @map("spots_available")
  spotsFilled        Int       @default(0) @map("spots_filled")
  city               String
  description        String?   @db.Text
  suggestedPayAmount Int?      @map("suggested_pay_amount")
  suggestedPayType   String?   @map("suggested_pay_type")
  startTime          String?   @map("start_time")
  endTime            String?   @map("end_time")
  contactDetails     String?   @map("contact_details") @db.Text
  date               String?
  applicants         Json      @default("[]")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  venue     Venue?     @relation(fields: [venueId], references: [id], onDelete: SetNull)
  event     Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  hostEvent HostEvent? @relation(fields: [hostEventId], references: [id], onDelete: SetNull)

  @@index([venueId])
  @@index([eventId])
  @@index([hostEventId])
  @@index([status])
  @@map("jobs")
}

model JobPosting {
  id                 String           @id @default(cuid())
  venueId            String           @map("venue_id")
  title              String
  description        String           @db.Text
  requirements       String           @db.Text
  jobType            JobType          @map("job_type")
  compensationType   CompensationType @map("compensation_type")
  compensationAmount Float?           @map("compensation_amount")
  compensationPer    CompensationPer  @map("compensation_per")
  currency           String           @default("ZAR")
  totalSpots         Int              @default(1) @map("total_spots")
  filledSpots        Int              @default(0) @map("filled_spots")
  closingDate        DateTime?        @map("closing_date")
  status             JobStatus        @default(OPEN)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  venue        Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  applications JobApplication[]
  messages     JobMessage[]

  @@index([venueId])
  @@index([status])
  @@index([createdAt])
  @@map("job_postings")
}

model JobApplication {
  id              String            @id @default(cuid())
  jobPostingId    String            @map("job_posting_id")
  applicantUserId String            @map("applicant_user_id")
  coverMessage    String            @map("cover_message") @db.Text
  cvUrl           String?           @map("cv_url")
  cvFileName      String?           @map("cv_file_name")
  portfolioUrl    String?           @map("portfolio_url")
  status          ApplicationStatus @default(PENDING)
  appliedAt       DateTime          @default(now()) @map("applied_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  jobPosting JobPosting   @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  applicant  User         @relation(fields: [applicantUserId], references: [id], onDelete: Cascade)
  messages   JobMessage[]

  @@unique([jobPostingId, applicantUserId])
  @@index([jobPostingId])
  @@index([applicantUserId])
  @@index([status])
  @@map("job_applications")
}

model JobMessage {
  id            String    @id @default(cuid())
  applicationId String    @map("application_id")
  jobPostingId  String    @map("job_posting_id")
  senderUserId  String    @map("sender_user_id")
  body          String    @db.Text
  sentAt        DateTime  @default(now()) @map("sent_at")
  readAt        DateTime? @map("read_at")

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  jobPosting  JobPosting     @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  sender      User           @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([jobPostingId])
  @@index([senderUserId])
  @@index([sentAt])
  @@index([readAt])
  @@map("job_messages")
}

model ServiceRating {
  id          String   @id @default(uuid())
  raterUserId String   @map("rater_user_id")
  rateeUserId String   @map("ratee_user_id")
  contextType String   @map("context_type")
  contextId   String   @map("context_id")
  score       Int
  message     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([rateeUserId, createdAt])
  @@index([contextType, contextId])
  @@map("service_ratings")
}

model Promotion {
  id                 String          @id @default(cuid())
  venueId            String          @map("venue_id")
  eventId            String?         @map("event_id")
  type               PromotionType   @map("promotion_type")
  title              String
  description        String          @db.Text
  imageUrl           String?         @map("image_url")
  imagePublicId      String?         @map("image_public_id")
  targetCity         String?         @map("target_city")
  status             PromotionStatus @default(DRAFT)
  startAt            DateTime        @map("start_at")
  endAt              DateTime        @map("end_at")
  boosted            Boolean         @default(false)
  boostedAt          DateTime?       @map("boosted_at")
  boostExpiresAt     DateTime?       @map("boost_expires_at")
  boostPaystackRef   String?         @map("boost_paystack_ref")
  boostImpressions   Int             @default(0) @map("boost_impressions")
  organicImpressions Int             @default(0) @map("organic_impressions")
  totalClicks        Int             @default(0) @map("total_clicks")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  deletedAt          DateTime?       @map("deleted_at")

  venue       Venue                 @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event       Event?                @relation(fields: [eventId], references: [id], onDelete: SetNull)
  impressions PromotionImpression[]

  @@index([venueId])
  @@index([status])
  @@index([eventId])
  @@index([targetCity])
  @@index([boosted, boostExpiresAt])
  @@map("promotions")
}

model PromotionImpression {
  id             String         @id @default(cuid())
  promotedPostId String         @map("promoted_post_id")
  userId         String?        @map("user_id")
  sessionId      String         @map("session_id")
  type           ImpressionType
  createdAt      DateTime       @default(now()) @map("created_at")

  promotedPost Promotion @relation(fields: [promotedPostId], references: [id], onDelete: Cascade)

  @@index([promotedPostId, createdAt])
  @@index([sessionId, promotedPostId, type, createdAt])
  @@map("promotion_impressions")
}

// ─── Tier 3: User Social / Blocks & Reports ───────────────────────────────
model Block {
  id        String   @id @default(uuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlockInitiator", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockTarget", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocks")
}

model Report {
  id         String       @id @default(uuid())
  reporterId String       @map("reporter_id")
  targetType String       @map("target_type")
  targetId   String       @map("target_id")
  reason     String
  details    String?
  status     ReportStatus @default(pending)
  resolvedBy String?      @map("resolved_by")
  resolvedAt DateTime?    @map("resolved_at")
  createdAt  DateTime     @default(now()) @map("created_at")

  reporter User @relation("ReportInitiator", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([reporterId])
  @@index([status])
  @@map("reports")
}

// ─── Supporting Models ────────────────────────────────────────────────────
model Chat {
  id             String    @id @default(uuid())
  relatedTableId String?   @map("related_table_id")
  lastMessageAt  DateTime? @map("last_message_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("chats")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id")
  senderId  String   @map("sender_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String?
  actionUrl String?  @map("action_url")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  venueId   String?  @map("venue_id")
  eventId   String?  @map("event_id")
  amount    Float
  currency  String   @default("ZAR")
  type      String
  status    String
  stripeId  String?  @map("stripe_id") // Paystack reference (legacy column name)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([venueId])
  @@map("transactions")
}

// Canonical Payment record — all Paystack payments stored here
model Payment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  email     String
  amount    Float
  reference String   @unique // Paystack reference
  status    String // pending | success | failed
  type      String // event | table | promotion | ticket | other
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([reference])
  @@index([status])
  @@index([type])
  @@map("payments")
}

model FriendRequest {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@map("friend_requests")
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String           @map("requester_id")
  receiverId  String           @map("receiver_id")
  status      FriendshipStatus
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("FriendReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
  @@index([requesterId])
  @@index([receiverId])
  @@index([status])
  @@map("friendships")
}

model Conversation {
  id             String    @id @default(cuid())
  participantAId String    @map("participant_a_id")
  participantBId String    @map("participant_b_id")
  lastMessageAt  DateTime? @map("last_message_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  participantA User            @relation("ConversationParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB User            @relation("ConversationParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  messages     DirectMessage[]

  @@unique([participantAId, participantBId])
  @@index([participantAId])
  @@index([participantBId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model DirectMessage {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  senderUserId   String    @map("sender_user_id")
  body           String    @db.Text
  readAt         DateTime? @map("read_at")
  sentAt         DateTime  @default(now()) @map("sent_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("DirectMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
  @@map("direct_messages")
}

model GroupChat {
  id            String    @id @default(cuid())
  eventId       String    @unique @map("event_id")
  name          String
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  event    Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  members  GroupChatMember[]
  messages GroupChatMessage[]

  @@index([lastMessageAt])
  @@map("group_chats")
}

model GroupChatMember {
  id          String    @id @default(cuid())
  groupChatId String    @map("group_chat_id")
  userId      String    @map("user_id")
  joinedAt    DateTime  @default(now()) @map("joined_at")
  lastReadAt  DateTime? @map("last_read_at")

  groupChat GroupChat @relation(fields: [groupChatId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupChatId, userId])
  @@index([groupChatId])
  @@index([userId])
  @@map("group_chat_members")
}

model GroupChatMessage {
  id           String   @id @default(cuid())
  groupChatId  String   @map("group_chat_id")
  senderUserId String   @map("sender_user_id")
  body         String   @db.Text
  sentAt       DateTime @default(now()) @map("sent_at")

  groupChat GroupChat @relation(fields: [groupChatId], references: [id], onDelete: Cascade)
  sender    User      @relation("GroupChatMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([groupChatId, sentAt])
  @@map("group_chat_messages")
}

model InAppNotification {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  type          NotificationType
  title         String
  body          String
  referenceId   String?          @map("reference_id")
  referenceType String?          @map("reference_type")
  read          Boolean          @default(false)
  createdAt     DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("in_app_notifications")
}

model FriendActivity {
  id            String             @id @default(cuid())
  userId        String             @map("user_id")
  activityType  FriendActivityType @map("activity_type")
  referenceId   String             @map("reference_id")
  referenceType String             @map("reference_type")
  description   String
  createdAt     DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("friend_activities")
}

// ─── Account roles (explicit: partygoer, host, business) — mapped to user_roles table ──
model AccountRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleType  String   @map("role_type") // partygoer | host | business
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, roleType])
  @@index([userId])
  @@index([roleType])
  @@map("user_roles")
}

// ─── Host Events (informal: house parties, boat parties, etc.) ─────────────
model HostEvent {
  id                    String    @id @default(uuid())
  hostUserId            String    @map("host_user_id")
  title                 String
  description           String?   @db.Text
  date                  DateTime
  location              String?
  city                  String?
  capacity              Int?
  entryCost             Float?    @map("entry_cost")
  guestApprovalRequired Boolean   @default(true) @map("guest_approval_required")
  status                String    @default("draft") // draft | published | cancelled
  coverImageUrl         String?   @map("cover_image_url")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  jobs Job[]

  @@index([hostUserId])
  @@index([date])
  @@index([status])
  @@map("host_events")
}

model UserReview {
  id            String    @id @default(cuid())
  reviewerId    String    @map("reviewer_id")
  subjectUserId String    @map("subject_user_id")
  eventId       String    @map("event_id")
  tableId       String?   @map("table_id")
  rating        Int
  comment       String    @db.Text
  flagged       Boolean   @default(false)
  flagReason    String?   @map("flag_reason") @db.Text
  flaggedAt     DateTime? @map("flagged_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  reviewer User   @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  subject  User   @relation("ReviewsReceived", fields: [subjectUserId], references: [id], onDelete: Cascade)
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  table    Table? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@unique([reviewerId, subjectUserId, eventId])
  @@index([subjectUserId])
  @@index([reviewerId])
  @@index([flagged])
  @@map("user_reviews")
}

// ─── Analytics ────────────────────────────────────────────────────────────
model AnalyticsEvent {
  id        String   @id @default(uuid())
  eventId   String?  @map("event_id")
  venueId   String?  @map("venue_id")
  userId    String?  @map("user_id")
  metric    String
  value     Float?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@index([venueId])
  @@index([metric])
  @@index([createdAt])
  @@map("analytics_events")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Premium Subscription Prep ────────────────────────────────────────────
model ProfileView {
  id        String   @id @default(uuid())
  viewerId  String   @map("viewer_id")
  viewedId  String   @map("viewed_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([viewerId])
  @@index([viewedId])
  @@index([createdAt])
  @@map("profile_views")
}

// ─── Reputation Scores (server-computed) ─────────────────────────────────
model ReputationScore {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  score              Float    @default(50)
  attendanceScore    Float    @default(0) @map("attendance_score")
  reportsReceived    Int      @default(0) @map("reports_received")
  blocksReceived     Int      @default(0) @map("blocks_received")
  eventParticipation Int      @default(0) @map("event_participation")
  tableParticipation Int      @default(0) @map("table_participation")
  computedAt         DateTime @default(now()) @map("computed_at")

  @@index([userId])
  @@index([score])
  @@map("reputation_scores")
}

// ─── Future: Live Venue Popularity ───────────────────────────────────────
model VenuePopularity {
  id              String   @id @default(uuid())
  venueId         String   @map("venue_id")
  eventId         String?  @map("event_id")
  currentCheckIns Int      @default(0) @map("current_check_ins")
  popularityScore Float    @default(0) @map("popularity_score")
  queueTime       Int?     @map("queue_time")
  lastUpdatedAt   DateTime @default(now()) @map("last_updated_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, eventId])
  @@index([venueId])
  @@index([popularityScore])
  @@map("venue_popularity")
}

// ─── Future: Table Booking & Split Payments ──────────────────────────────
model TableBooking {
  id              String   @id @default(uuid())
  tableId         String   @map("table_id")
  organizerUserId String   @map("organizer_user_id")
  totalCost       Float    @map("total_cost")
  splitCount      Int      @default(1) @map("split_count")
  status          String   @default("pending")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  table  Table               @relation(fields: [tableId], references: [id], onDelete: Cascade)
  splits TableBookingSplit[]

  @@index([tableId])
  @@index([organizerUserId])
  @@index([status])
  @@map("table_bookings")
}

model TableBookingSplit {
  id            String    @id @default(uuid())
  bookingId     String    @map("booking_id")
  userId        String    @map("user_id")
  amount        Float
  paymentStatus String    @default("pending") @map("payment_status")
  paymentRef    String?   @map("payment_ref")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  booking TableBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, userId])
  @@index([bookingId])
  @@index([userId])
  @@index([paymentStatus])
  @@map("table_booking_splits")
}

// ─── Future: Party Groups / Crews ────────────────────────────────────────
model PartyGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  avatarUrl   String?  @map("avatar_url")
  createdBy   String   @map("created_by")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members     PartyGroupMember[]
  invitations PartyGroupInvitation[]
  events      PartyGroupEvent[]

  @@index([createdBy])
  @@map("party_groups")
}

model PartyGroupMember {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  group PartyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("party_group_members")
}

model PartyGroupInvitation {
  id          String    @id @default(uuid())
  groupId     String    @map("group_id")
  inviterId   String    @map("inviter_id")
  inviteeId   String    @map("invitee_id")
  status      String    @default("pending")
  createdAt   DateTime  @default(now()) @map("created_at")
  respondedAt DateTime? @map("responded_at")

  group PartyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, inviteeId])
  @@index([groupId])
  @@index([inviteeId])
  @@index([status])
  @@map("party_group_invitations")
}

model PartyGroupEvent {
  id        String    @id @default(uuid())
  groupId   String    @map("group_id")
  eventId   String?   @map("event_id")
  venueId   String?   @map("venue_id")
  title     String
  date      DateTime?
  status    String    @default("planning")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  group PartyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([eventId])
  @@map("party_group_events")
}
