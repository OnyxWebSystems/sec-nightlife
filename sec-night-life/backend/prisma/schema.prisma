  @@index([jobPostingId])
  @@index([applicantUserId])
  @@index([status])
  @@map("job_applications")
}

model JobMessage {
  id            String    @id @default(cuid())
  applicationId String    @map("application_id")
  jobPostingId  String    @map("job_posting_id")
  senderUserId  String    @map("sender_user_id")
