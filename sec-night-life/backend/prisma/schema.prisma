generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  VENUE
  FREELANCER
  ADMIN
  MODERATOR
}

enum VenueComplianceStatus {
  pending
  approved
  rejected
}

enum EventStatus {
  draft
  published
  cancelled
}

enum TableStatus {
  open
  full
  closed
}

enum ReportStatus {
  pending
  resolved
  dismissed
}

// ─── Users & Auth ─────────────────────────────────────────────────────────
model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  role              UserRole  @default(USER)
  fullName          String?   @map("full_name")
  emailVerified          Boolean   @default(false) @map("email_verified")
  verificationTokenHash  String?   @map("verification_token_hash")
  verificationExpiry     DateTime? @map("verification_expiry")
  resetTokenHash         String?   @map("reset_token_hash")
  resetTokenExpiry       DateTime? @map("reset_token_expiry")
  isPremium         Boolean   @default(false) @map("is_premium")
  suspendedAt       DateTime? @map("suspended_at")
  suspendedReason   String?   @map("suspended_reason")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  // Relations
  venueOwner        Venue[]   @relation("VenueOwner")
  userProfile       UserProfile?
  hostedTables      Table[]   @relation("TableHost")
  blocksInitiated   Block[]   @relation("BlockInitiator")
  blocksReceived    Block[]   @relation("BlockTarget")
  reportsInitiated  Report[]  @relation("ReportInitiator")
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model UserProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  username           String?
  bio                String?
  city               String?
  avatarUrl          String?  @map("avatar_url")
  ageVerified        Boolean  @default(false) @map("age_verified")
  isVerifiedPromoter Boolean  @default(false) @map("is_verified_promoter")
  socialReputation   Float    @default(0) @map("social_reputation")
  behaviourScore     Float    @default(100) @map("behaviour_score")
  interests          String[] @default([])
  musicPreferences   String[] @default([]) @map("music_preferences")
  friends            String[] @default([])
  onboardingComplete Boolean  @default(false) @map("onboarding_complete")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ─── Tier 1: Venues ───────────────────────────────────────────────────────
model Venue {
  id                String              @id @default(uuid())
  ownerUserId       String              @map("owner_user_id")
  name              String
  venueType         String              @map("venue_type")
  city              String
  address           String?
  latitude          Float?
  longitude         Float?
  bio               String?
  isVerified        Boolean             @default(false) @map("is_verified")
  complianceStatus  VenueComplianceStatus @default(pending) @map("compliance_status")
  logoUrl           String?             @map("logo_url")
  coverImageUrl     String?             @map("cover_image_url")
  phone             String?
  email             String?
  website           String?
  instagram         String?
  capacity          Int?
  ageLimit          Int?                @map("age_limit")
  rating            Float               @default(0)
  ratingCount       Int                 @default(0) @map("rating_count")
  performanceScore  Float               @default(0) @map("performance_score")
  transparencyScore Float               @default(0) @map("transparency_score")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  deletedAt         DateTime?           @map("deleted_at")

  owner   User    @relation("VenueOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  events  Event[]
  tables  Table[]
  jobs    Job[]
  reviews VenueReview[]
  blockedUsers VenueBlockedUser[]

  @@index([ownerUserId])
  @@index([city])
  @@index([complianceStatus])
  @@map("venues")
}

model VenueReview {
  id               String   @id @default(uuid())
  venueId          String   @map("venue_id")
  eventId          String?  @map("event_id")
  userId           String   @map("user_id")
  rating           Int
  comment          String?
  metadata         Json?    // atmosphere_rating, service_rating, value_rating, verified_attendance
  createdAt        DateTime @default(now()) @map("created_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([userId])
  @@index([eventId])
  @@map("venue_reviews")
}

model VenueBlockedUser {
  id        String   @id @default(uuid())
  venueId   String   @map("venue_id")
  userId    String   @map("user_id")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, userId])
  @@index([venueId])
  @@map("venue_blocked_users")
}

// ─── Events & Tables ──────────────────────────────────────────────────────
model Event {
  id             String      @id @default(uuid())
  venueId        String      @map("venue_id")
  title          String
  description    String?
  date           DateTime
  city           String
  status         EventStatus @default(draft)
  isFeatured     Boolean     @default(false) @map("is_featured")
  coverImageUrl  String?     @map("cover_image_url")
  bannerUrl      String?     @map("banner_url")
  ticketTiers    Json?       @map("ticket_tiers")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  venue    Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  tables   Table[]
  jobs     Job[]
  attendees EventAttendance[]

  @@index([venueId])
  @@index([date])
  @@index([status])
  @@index([city])
  @@map("events")
}

model EventAttendance {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  userId    String   @map("user_id")
  confirmed Boolean  @default(false)
  checkedIn Boolean  @default(false) @map("checked_in")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("event_attendance")
}

model Table {
  id            String      @id @default(uuid())
  eventId       String      @map("event_id")
  venueId       String      @map("venue_id")
  hostUserId    String      @map("host_user_id")
  name          String
  status        TableStatus @default(open)
  maxGuests     Int         @map("max_guests")
  currentGuests Int         @default(0) @map("current_guests")
  minSpend      Float?      @map("min_spend")
  joiningFee    Float?      @map("joining_fee")
  members       Json        @default("[]")
  pendingRequests Json      @default("[]") @map("pending_requests")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  host  User  @relation("TableHost", fields: [hostUserId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([venueId])
  @@index([hostUserId])
  @@index([status])
  @@map("tables")
}

// ─── Tier 2: Freelancers / Jobs ───────────────────────────────────────────
model Job {
  id             String   @id @default(uuid())
  venueId        String   @map("venue_id")
  eventId        String   @map("event_id")
  title          String
  jobType        String   @map("job_type")
  status         String   @default("open")
  spotsAvailable Int      @map("spots_available")
  spotsFilled    Int      @default(0) @map("spots_filled")
  city           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@index([eventId])
  @@index([status])
  @@map("jobs")
}

// ─── Tier 3: User Social / Blocks & Reports ───────────────────────────────
model Block {
  id          String   @id @default(uuid())
  blockerId   String   @map("blocker_id")
  blockedId   String   @map("blocked_id")
  createdAt   DateTime @default(now()) @map("created_at")

  blocker User @relation("BlockInitiator", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockTarget", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocks")
}

model Report {
  id          String      @id @default(uuid())
  reporterId  String      @map("reporter_id")
  targetType  String      @map("target_type")
  targetId    String      @map("target_id")
  reason      String
  details     String?
  status      ReportStatus @default(pending)
  resolvedBy  String?     @map("resolved_by")
  resolvedAt  DateTime?   @map("resolved_at")
  createdAt   DateTime    @default(now()) @map("created_at")

  reporter User @relation("ReportInitiator", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([reporterId])
  @@index([status])
  @@map("reports")
}

// ─── Supporting Models ────────────────────────────────────────────────────
model Chat {
  id               String   @id @default(uuid())
  relatedTableId   String?  @map("related_table_id")
  lastMessageAt    DateTime? @map("last_message_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("chats")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id")
  senderId  String   @map("sender_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String?
  actionUrl String?  @map("action_url")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  venueId     String?  @map("venue_id")
  eventId     String?  @map("event_id")
  amount      Float
  currency    String   @default("ZAR")
  type        String
  status      String
  stripeId    String?  @map("stripe_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([venueId])
  @@map("transactions")
}

model FriendRequest {
  id          String   @id @default(uuid())
  fromUserId  String   @map("from_user_id")
  toUserId    String   @map("to_user_id")
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
  @@map("friend_requests")
}

// ─── Analytics ────────────────────────────────────────────────────────────
model AnalyticsEvent {
  id         String   @id @default(uuid())
  eventId    String?  @map("event_id")
  venueId    String?  @map("venue_id")
  userId     String?  @map("user_id")
  metric     String
  value      Float?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@index([venueId])
  @@index([metric])
  @@index([createdAt])
  @@map("analytics_events")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Premium Subscription Prep ────────────────────────────────────────────
model ProfileView {
  id         String   @id @default(uuid())
  viewerId   String   @map("viewer_id")
  viewedId   String   @map("viewed_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([viewerId])
  @@index([viewedId])
  @@index([createdAt])
  @@map("profile_views")
}

// ─── Reputation Scores (server-computed) ─────────────────────────────────
model ReputationScore {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  score               Float    @default(50)
  attendanceScore     Float    @default(0) @map("attendance_score")
  reportsReceived     Int      @default(0) @map("reports_received")
  blocksReceived      Int      @default(0) @map("blocks_received")
  eventParticipation  Int      @default(0) @map("event_participation")
  tableParticipation  Int      @default(0) @map("table_participation")
  computedAt          DateTime @default(now()) @map("computed_at")

  @@index([userId])
  @@index([score])
  @@map("reputation_scores")
}
