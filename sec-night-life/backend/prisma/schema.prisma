}

model VenueTable {
  id                String           @id @default(cuid())
  venueId           String           @map("venue_id")
  eventId           String?          @map("event_id")
  tableName         String           @map("table_name")
  description       String?          @db.Text
  guestCapacity     Int              @map("guest_capacity")
  currentOccupancy  Int              @default(0) @map("current_occupancy")
  minimumSpend      Float            @map("minimum_spend")
  bookingFeeZar     Float            @default(0) @map("booking_fee_zar")
  hostTableFeeZar   Float            @default(0) @map("host_table_fee_zar")
  minSpendSettlement MinSpendSettlement @default(PAY_ON_ARRIVAL) @map("min_spend_settlement")
  amountContributed Float            @default(0) @map("amount_contributed")
  serviceDate       DateTime?        @map("service_date")
  startTime         String?          @map("start_time")
  endTime           String?          @map("end_time")
  partySize         Int?             @map("party_size")
  isCustomListing   Boolean          @default(false) @map("is_custom_listing")
  allowsCustomRequests Boolean       @default(false) @map("allows_custom_requests")
  tierLabel         String?          @map("tier_label")
  hostingTierKey    String?          @map("hosting_tier_key")
  includedItems     Json?            @map("included_items")
  status            VenueTableStatus @default(AVAILABLE)
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  venue     Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  event     Event?               @relation(fields: [eventId], references: [id], onDelete: SetNull)
  members   VenueTableMember[]
  menuItems VenueTableMenuItem[]
  splitLogs SplitPaymentLog[]

  @@index([venueId])
  @@index([status])
  @@map("venue_tables")
}

model VenueTableMember {
  id                String                 @id @default(cuid())
  venueTableId      String                 @map("venue_table_id")
  userId            String                 @map("user_id")
  amountPaid        Float                  @default(0) @map("amount_paid")
  paystackReference String?                @map("paystack_reference")
  selectedMenuItems Json?                  @map("selected_menu_items")
  userSpecs         Json?                  @map("user_specs")
  declineReason     String?                @map("decline_reason") @db.Text
  reviewedAt        DateTime?              @map("reviewed_at")
  reviewedByUserId  String?                @map("reviewed_by_user_id")
  settlementMode    MinSpendSettlement?    @map("settlement_mode")
  status            VenueTableMemberStatus @default(PENDING_PAYMENT)
  joinedAt          DateTime               @default(now()) @map("joined_at")
  paidAt            DateTime?              @map("paid_at")

  venueTable VenueTable        @relation(fields: [venueTableId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  splitLogs  SplitPaymentLog[]

  @@unique([venueTableId, userId])
  @@index([venueTableId])
  @@index([userId])
  @@map("venue_table_members")
}

model VenueTableMenuItem {
  id           String  @id @default(cuid())
  venueTableId String  @map("venue_table_id")
  venueMenuItemId String? @map("venue_menu_item_id")
  name         String
  category     String
  price        Float
  imageUrl     String? @map("image_url")
  isAvailable  Boolean @default(true) @map("is_available")

  venueTable VenueTable @relation(fields: [venueTableId], references: [id], onDelete: Cascade)

  @@index([venueTableId])
  @@map("venue_table_menu_items")
}

model SplitPaymentLog {
  id           String   @id @default(cuid())
  venueTableId String   @map("venue_table_id")
  memberId     String   @map("member_id")
  totalAmount  Float    @map("total_amount")
  secAmount    Float    @map("sec_amount")
  venueAmount  Float    @map("venue_amount")
  reference    String
  createdAt    DateTime @default(now()) @map("created_at")

  venueTable VenueTable       @relation(fields: [venueTableId], references: [id], onDelete: Cascade)
  member     VenueTableMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([venueTableId])
  @@index([memberId])
  @@index([reference])
  @@map("split_payment_logs")
}

model HostedTableMember {
  id                String         @id @default(cuid())
  hostedTableId     String         @map("hosted_table_id")
  userId            String         @map("user_id")
  status            AttendeeStatus
  joinedAt          DateTime       @default(now()) @map("joined_at")
  hostReviewedAt    DateTime?      @map("host_reviewed_at")
  declineReason     String?        @map("decline_reason") @db.Text
  paystackReference String?        @map("paystack_reference")
  joinFeePaid      Float?         @map("join_fee_paid")
  selectedMenuItems Json?         @map("selected_menu_items")
  menuSpendPaid     Float          @default(0) @map("menu_spend_paid")

  hostedTable HostedTable @relation(fields: [hostedTableId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hostedTableId, userId])
  @@index([hostedTableId])
  @@index([userId])
  @@map("hosted_table_members")
}

model TableInvite {
  id            String       @id @default(cuid())
  hostedTableId String       @map("hosted_table_id")
  inviterUserId String       @map("inviter_user_id")
  inviteeUserId String       @map("invitee_user_id")
  status        InviteStatus @default(PENDING)
  sentAt        DateTime     @default(now()) @map("sent_at")
  respondedAt   DateTime?    @map("responded_at")

  hostedTable HostedTable @relation(fields: [hostedTableId], references: [id], onDelete: Cascade)
  inviter     User        @relation("TableInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)
  invitee     User        @relation("TableInvitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)

  @@unique([hostedTableId, inviteeUserId])
  @@index([inviteeUserId])
  @@map("table_invites")
}

model HousePartyJob {
  id                 String           @id @default(cuid())
  housePartyId       String           @map("house_party_id")
  hostUserId         String           @map("host_user_id")
  title              String
  description        String           @db.Text
  requirements       String           @db.Text
  jobType            JobType          @map("job_type")
  compensationType   CompensationType @map("compensation_type")
  compensationAmount Float?           @map("compensation_amount")
  compensationPer    CompensationPer  @map("compensation_per")
  currency           String           @default("ZAR")
  totalSpots         Int              @default(1) @map("total_spots")
  filledSpots        Int              @default(0) @map("filled_spots")
  closingDate        DateTime?        @map("closing_date")
  status             JobStatus        @default(OPEN)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  houseParty   HouseParty                 @relation(fields: [housePartyId], references: [id], onDelete: Cascade)
  host         User                       @relation("HousePartyJobHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  applications HousePartyJobApplication[]

  @@index([housePartyId])
  @@index([hostUserId])
  @@index([status])
  @@map("house_party_jobs")
}

model HousePartyJobApplication {
  id              String            @id @default(cuid())
  housePartyJobId String            @map("house_party_job_id")
  applicantUserId String            @map("applicant_user_id")
  coverMessage    String            @map("cover_message") @db.Text
  cvUrl           String?           @map("cv_url")
  cvFileName      String?           @map("cv_file_name")
  portfolioUrl    String?           @map("portfolio_url")
  status          ApplicationStatus @default(PENDING)
  appliedAt       DateTime          @default(now()) @map("applied_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  housePartyJob HousePartyJob          @relation(fields: [housePartyJobId], references: [id], onDelete: Cascade)
  applicant     User                   @relation(fields: [applicantUserId], references: [id], onDelete: Cascade)
  messages      HousePartyJobMessage[]

  @@unique([housePartyJobId, applicantUserId])
  @@index([housePartyJobId])
  @@index([applicantUserId])
  @@index([status])
  @@map("house_party_job_applications")
}

model HousePartyJobMessage {
  id            String    @id @default(cuid())
  applicationId String    @map("application_id")
  senderUserId  String    @map("sender_user_id")
  body          String    @db.Text
  sentAt        DateTime  @default(now()) @map("sent_at")
  readAt        DateTime? @map("read_at")

  application HousePartyJobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  sender      User                     @relation("HousePartyJobMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([senderUserId])
  @@index([sentAt])
  @@map("house_party_job_messages")
}

model UserReview {
  id            String    @id @default(cuid())
  reviewerId    String    @map("reviewer_id")
  subjectUserId String    @map("subject_user_id")
  eventId       String    @map("event_id")
  tableId       String?   @map("table_id")
  rating        Int
  comment       String    @db.Text
  flagged       Boolean   @default(false)
  flagReason    String?   @map("flag_reason") @db.Text
  flaggedAt     DateTime? @map("flagged_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  reviewer User   @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  subject  User   @relation("ReviewsReceived", fields: [subjectUserId], references: [id], onDelete: Cascade)
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  table    Table? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@unique([reviewerId, subjectUserId, eventId])
  @@index([subjectUserId])
  @@index([reviewerId])
  @@index([flagged])
  @@map("user_reviews")
}

// ─── Analytics ────────────────────────────────────────────────────────────
model AnalyticsEvent {
