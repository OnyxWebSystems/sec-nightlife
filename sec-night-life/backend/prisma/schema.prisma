model Ticket {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  kind              TicketKind
  title             String
  subtitle          String?   @db.Text
  paystackReference String    @unique @map("paystack_reference")
  qrToken           String    @unique @map("qr_token")
  housePartyId      String?   @map("house_party_id")
  tableId           String?   @map("table_id")
  hostedTableId     String?   @map("hosted_table_id")
  eventId           String?   @map("event_id")
  venueTableId      String?   @map("venue_table_id")
  quantity          Int       @default(1)
  visibleUntil      DateTime  @map("visible_until")
  createdAt         DateTime  @default(now()) @map("created_at")

  /// Snapshot of payer display name at issuance (door check).
  holderDisplayName   String?   @map("holder_display_name")
  /// Human-readable table/tier context at issuance.
  tableSpecsSummary   String?   @db.Text @map("table_specs_summary")
  /// Canonical event start (UTC) for expiry: active until eventStartsAt + 24h.
  eventStartsAt       DateTime? @map("event_starts_at")
  /// User hid this ticket from Profile history (soft delete).
  hiddenFromHistoryAt DateTime? @map("hidden_from_history_at")
  admittedAt          DateTime? @map("admitted_at")
  admittedByUserId    String?   @map("admitted_by_user_id")

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  admittedBy User? @relation("TicketAdmittedBy", fields: [admittedByUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([visibleUntil])
  @@index([eventStartsAt])
  @@index([admittedAt])
  @@map("tickets")
}

