{
  "version": 2,
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/health"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/expire-promotions",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/complete-parties",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/expire-table-boosts",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/event-interest-reminders",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/weekend-reminder",
      "schedule": "0 10 * * 5"
    }
  ]
}

