<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Copy to GoogleService-Info.plist after founder creates Firebase iOS app.
  See docs/FIREBASE_PUSH_SETUP.md
-->
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>FOUNDER_FIREBASE_IOS_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>FOUNDER_FIREBASE_PROJECT_NUMBER</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.secnightlife.app</string>
	<key>PROJECT_ID</key>
	<string>sec-nightlife</string>
	<key>STORAGE_BUCKET</key>
	<string>sec-nightlife.appspot.com</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>GOOGLE_APP_ID</key>
	<string>1:FOUNDER_FIREBASE_PROJECT_NUMBER:ios:FOUNDER_APP_ID</string>
</dict>
</plist>
